# Database
DATABASE_URL="postgresql://user:password@localhost:5432/snc_beauty_salon"

# NextAuth v5 — generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"
AUTH_URL="http://localhost:3000"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLIC_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Email (Resend — https://resend.com)
RESEND_API_KEY="re_..."
# Sender address — must be a verified domain in your Resend account.
# Use the resend.dev sandbox address for local testing.
RESEND_FROM="SNC Beauty Salon & Spa <no-reply@resend.dev>"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Salon contact info (shown in confirmation emails)
SALON_PHONE="+1 (514) 000-0000"
SALON_EMAIL="contact@sncbeautysalon.com"
SALON_ADDRESS="123 Beauty Street, Montreal, QC"

# Cron job security — generate with: openssl rand -hex 32
CRON_SECRET="your-cron-secret-here"

# Schedule for intake form reminder emails (cron syntax, UTC)
# Default: 9:00 AM UTC daily. Use https://crontab.guru to build expressions.
CRON_REMINDER_TIME="0 9 * * *"
